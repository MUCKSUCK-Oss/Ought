{
  "manifest_version": 3,
  "name": "Ought",
  "version": "1.1.0",
  "description": "Popup workspace manager.",
  "action": {
    "default_popup": "popup.html"
  },
  "permissions": ["storage", "tabs"],
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/watch*"],
      "js": ["youtube-tracker.js"],
      "run_at": "document_idle"
    }
  ]
}
